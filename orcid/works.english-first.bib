@article{ART003296700,
  author = {Son, Jeyoun},
  title = {The Interpretive Convergence Theory of Law},
  journal = {Korean Journal of Legal Philosophy},
  year = {2025},
  volume = {28},
  number = {3},
  pages = {199-237},
  month = {Dec. 31.},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART003296700},
  keywords = {Interpretive Convergence Theory of Law, Legal Positivism, Interpretivism, Legal Normativity, Emergentism, uptake},
  abstract = {This paper develops an alternative to the two dominant approaches in jurisprudence ―legal positivism which emphasizes master rule or pedigree, and moral interpretivism― by offering a new account of how legal norms arise and why they bind. According to this view, the normativity of law emerges through a process of interpretive convergence within a community, and law itself is generated via the discursive transformation of authoritative acts (such as statutes or judicial decisions) and other legally oriented acts into legal meaning. Legal institutions (legislatures, courts, agencies), along with various social actors, perform acts intended to influence behavior within a legal framework, but those acts acquire legal content and force only through their uptake and iterative interpretation by participants in a shared discourse. Roughly, the law is the product of convergent interpretive engagement with the outputs of legal acts and legally meaningful social practices, yielding an emergent set of norms that the community comes to treat as binding. I call this view the ‘Interpretive Convergence Theory of Law’ because it maintains that legal obligations are those normative propositions that crystallize from the collective interpretive practices of the legal community. In what follows, I motivate this theory by highlighting a foundational puzzle about legal normativity and meaning, critique the prevailing positivist and interpretivist accounts, and then articulate the positive emergentist view in detail. I argue that this approach illuminates how law’s content and its authority are grounded in social practice rather than in any single rule or moral criterion. The theory explains how legal norms achieve their binding force through mutual expectations and discursive validation, framing law as a dynamic, evolving property of institutional practices and public reason. After developing the core framework, the paper explores implications for legal interpretation and the resolution of disagreement, and addresses potential objections (such as persistent disagreement and the risk of immoral convergences).},
  language = {en},
  title_native = {법의 해석적 수렴 이론},
  journal_native = {법철학연구},
  source_work_id = {ART003296700}
}

@article{ART003080283,
  author = {Son, Jeyoun},
  title = {The Validity of Law and the Radbruch Formula},
  journal = {Korean Journal of Legal Philosophy},
  year = {2024},
  volume = {27},
  number = {1},
  pages = {85-148},
  month = {Apr. 30.},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART003080283},
  keywords = {Gustav Radbruch, Radbruch Formula, Validity of Law, Law and Morality, Reason-Based Account, Legal Obligation},
  abstract = {Gustav Radbruch’s scholarship and his theory on the validity of law, especially the Radbruch Formula, provide an insightful response to the moral failures of the Nazi legal system and continue to influence modern legal and ethical discourse. However, the discourse on legal validity still seems to lack a proper consensus, starting from the handling of the concept to the stage of terminology use. This paper begins with the controversies sparked by Radbruch’s legal philosophy and the concept of legal validity, seeking a more fundamental approach to discussions on legal validity. It critically evaluates the implications of Radbruch’s relativism for a general theory of the existence of law, i.e., a theory of legal validity, examines the somewhat negative impact of Robert Alexy’s unique discussions on the “concept of validity(Geltungsbegriffe)” on domestic discourse, and argues that providing a reason-based account of legal obligation is crucial for an appropriate theoretical account of the issue of legal validity. To this end, Radbruch’s views are compared and contrasted with the theories of Robert Alexy, H.L.A. Hart, Lon Fuller, and Joseph Raz. Through this, the paper aims to reassess the significance of Radbruch’s legal theory and deepen the contemporary understanding of legal validity.},
  language = {en},
  title_native = {법의 유효성 문제와 라드브루흐 공식},
  journal_native = {법철학연구},
  source_work_id = {ART003080283}
}

@article{ART002937726,
  author = {Son, Jeyoun},
  title = {Legal Education in Undergraduate GE Courses},
  journal = {Korean Journal of Law & Society},
  year = {2023},
  number = {72},
  pages = {33-73},
  month = {Feb. 28.},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART002937726},
  keywords = {Liberal Education, General Education, Education on Law for Undergraduates, Law School},
  abstract = {Legal education in undergraduate GE courses should foster the ability to present the best explanation of legal phenomena in a society and the ability to find justifiable grounds for its legitimate legal system. Such education should incorporate a process that encourages students to justify their arguments based on their own logical reasoning. In this paper, usefulness and importance of liberal education are reviewed in first. Secondly, some peculiar reasons why liberal education has not been established in our society are examined. Thirdly, it is proposed why some education of law should be an essential part of liberal education. Finally, I suggest some directions for liberal and democratic education of law and offer some details of the curriculum and practical guides for legal GE classes.},
  language = {en},
  title_native = {학부 교양 교과로서의 법교육},
  journal_native = {법과사회},
  source_work_id = {ART002937726}
}

@article{ART002912830,
  author = {Son, Jeyoun},
  title = {An Inconvenient Truth of Weak AI: Fear of the Predictable, Not Fear of the uneXplainable},
  journal = {The Korean Journal of Ethics},
  year = {2022},
  volume = {11},
  number = {2},
  pages = {71-110},
  month = {Dec. 31.},
  doi = {10.38199/KJE.11.6},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART002912830},
  keywords = {weak AI, mutual ignorance, credit society, personalized information, mutual coorperation, explainability, accountability, trustworthy AI},
  abstract = {As paradoxical as it may sound, the easier it becomes for credit rating agencies in a society to predict individual credit, the less likely it is for the society to be a credit-based society. This is because mutual cooperation to prepare for an unpredictable future is based on mutual ignorance of personalized information between members. In a society where personalized information that makes possible predictions for each person increases, people who know but hide such information about themselves in cooperation are regarded as free riders or cheaters. As a result, it becomes more difficult to expect mutual cooperation through the free market for the realization of ordinary welfare, which has been previously considered to be achieved more efficiently through cooperation through the market rather than through social planning. However, any attempts of denying the positive function of individualized information or completely blocking its increase and distribution are not only unpromising, but also undesirable. What is clear is that in many areas that have relied on markets for the achievement of vital value(s) of liberalism or even utilitarianism, it is no longer reasonable to rely solely on the probability of mutual cooperation in the free market. It is the current weak artificial intelligence technology that is rapidly increasing individualized predictive information. It can be seen from this that the crisis facing in the era of weak AI is not a further intensification of the traditional problems such as black-box of a technology or misuse of personal information, but is a new type of grave crisis in which significant loss of mutual cooperation arises from technology with enhanced individual prediction. Moreover, regulatory prescriptions against the black-box nature of AI, such as ‘eXplainable AI’ or ‘trustworthy AI’, seem to be based in many cases on unreflective and superficial counterfeits from old ethical debates, which can only lead people to ethics-washing and -bashing.},
  language = {en},
  title_native = {약인공지능 시대의 윤리적 위기: 개별화된 예측 정보의 증가로 인한 상호협력 기반의 상실},
  journal_native = {윤리학},
  source_work_id = {ART002912830}
}

@article{ART002923254,
  author = {Son, Jeyoun},
  title = {Some Misconceptions about the Inner Morality of Law},
  journal = {Korean Journal of Legal Philosophy},
  year = {2022},
  volume = {25},
  number = {3},
  pages = {139-164},
  month = {Dec. 31.},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART002923254},
  keywords = {Lon Fuller, inner morality of law, formalism, functionalism, procedural natural law theory, the rule of law},
  abstract = {Treating Lon Fuller’s discussion as implicitly equivalent to “the rule of law”, “das Rechtsstaatsprinzip”, “procedural theory of natural law”, or “formalism”, prevents a coherent understanding of his conception of law. This article examines that there are certain limitations when understanding Fuller’s argument as a natural law theory in the sense of overcoming legal positivism, and furthermore, his suggestion of famous eight desiderata should not be regarded as a defense for legal formalism or functionalism, or the rule of law in a wide sense. The starting point of Fuller’s legal theory should be understood in his interactive thoughts of eunomics, rather than formalism, functionalism, or a procedural theory.},
  language = {en},
  title_native = {풀러의 법의 내적 도덕성에 대한 오해},
  journal_native = {법철학연구},
  source_work_id = {ART002923254}
}

@article{ART002921497,
  author = {Son, Jeyoun},
  title = {Development of a Writing Ability Diagnosis System for University First-year Students － The Seoul National University Essay Examination},
  journal = {The Korean Journal of Literacy Research},
  year = {2022},
  volume = {13},
  number = {6},
  pages = {45-76},
  month = {Dec. 30.},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART002921497},
  keywords = {college writing, writing test, first-year essay examination, writing ability diagnosis test, test development},
  abstract = {Assessing the writing ability of first-year students is essential for providing writing education to students having various levels of writing ability in college.This study examined various cases in Korea and abroad to develop a writing test for freshmen at Seoul National University (SNU) and then, devised a test design plan based on a literature review. In the design stage, the purpose and object of the test, tasks and recruitment process, and test environment were described. The actual test developed according to the design plan and its implementation process were investigated and methods and tools for analyzing and interpreting the test results were introduced. In the interpretation stage, a standard was set to provide helpful information for test stakeholders. Moreover, equating methods were used to identify the trends of freshmen’s writing ability annually. Finally, this study discussed research issues and implications arising in the design, implementation, and use of the test. Among the writing tests that have not been studied in the field of college writing education, this study aimed to develop a diagnostic test for firstyear students. As the test was developed as a single system and in a unified process, this study has significant implications not only for continuously implementing and stabilizing the essay examination for SNU first-year students, but for further research on the development of large-scale writing tests for university entrants.},
  language = {en},
  title_native = {대학 신입생의 글쓰기 능력 진단 체제 개발 연구 - 서울대학교 신입생 글쓰기 평가를 중심으로},
  journal_native = {리터러시 연구},
  source_work_id = {ART002921497}
}

@article{ART002753846,
  author = {Son, Jeyoun},
  title = {Infection as Bad Luck: The Right and Responsibility of Autonomous Agents in Pandemics},
  journal = {Korean Journal of Legal Philosophy},
  year = {2021},
  volume = {24},
  number = {2},
  pages = {297-340},
  month = {Aug. 31.},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART002753846},
  keywords = {Liberalism, Luck Egalitarianism, Vector Argument, COVID-19, Pandemic, Sonderopfertheorie},
  abstract = {A common and easy reason that justifies the sharp increase in personal responsibilities and severe restrictions on individual liberty due to the pandemic is based on the existence of public health crisis in which private interests might retreat to gigantic and urgent public interests. However, a coherent liberal theory must replace this naïve description of a retreat with an attributi on to the responsibility of the free individual.For such a review, this paper first critically analyzes the so-called “vector argument,” which is emerging as a powerful alternative to defend the expansion of personal responsibilities and duties in a pandemic from a liberal point of view. Those who take the vector argument argue that individual actions can causally attribute the consequences of increased harm from the brute fact that the human body can be a vector of viruses and therefore it is possible to attribute and extend civil and criminal liability for the widespread and increased harm of a pandemic asymmetrically to some individuals physically adjacent to viruses and infections.However, this paper confirms that most of the losses and harms that occur in this pandemic are simply due to brute misfortune inflicted on everyone and these are natural disasters that cannot be attributed to the free actions of individuals. Acknowledging this fact undermines the argument for extending individual responsibility in a pandemic situation, and therefore the principles from the vector argument results in unfairly passing the buck that the community should bear jointly and equally to only a few individuals.This paper in turn certifies that the distribution of responsibility for the cost of restoring social losses caused by bad luck for which no one is responsible should be based on the prima facie principle of symmetrically equal distribution. It is, of course, acceptable that the distribution of roles in consideration of an efficient division of labor can sometimes be attributed asymmetrically on the basis of a free Social Contract to individuals who can minimize losses by being socially close to the source of harm. However, it is clear that this justification concerns only the asymmetric distribution of roles, not of costs and risks to the party who has been responsible only for the efficient division of labor and thus it is necessary to be accompanied by common sharing of the management costs of other people's affairs in order to give them roles of prevention and restoration.Finally, this paper emphasizes that the more fundamental and urgent request caused by the pandemic is not a matter of additional responsibility and cost burden due to the intentional national prevention policy on epidemic or violation of individual obligations, but rather a redistribution matter caused by the disaster itself. It points out the fact that the governmental intervention policy sometimes overlooks that a pandemic is a disaster that has already caused seriously asymmetric bad lucks among individuals in different circumstances. Noting the injustice of a passive policy that neglects the increase in distributional inequity and the matter of risk-taking of losses due to the disaster, this paper reconfirms that it should be done as soon as possible to share the cost of restoration for the loss of society caused only by misfortune for which no one is responsible. This is not based on any benevolent welfare state perspective, but on the liberal one. In other words, the liberal state must not evade its careful and urgent duty of offsetting the consequences of bad luck, which is being called for by those who are more vulnerable to disasters.},
  language = {en},
  title_native = {불운으로서의 감염: 팬데믹 상황에서 자율적 행위자의 권리와 책임},
  journal_native = {법철학연구},
  source_work_id = {ART002753846}
}

@article{ART002714278,
  author = {Son, Jeyoun},
  title = {A Critical Analysis of Dokyun Kim’s Theory of Justice in Korea},
  journal = {Korean Journal of Legal Philosophy},
  year = {2021},
  volume = {24},
  number = {1},
  pages = {273-312},
  month = {Apr. 30.},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART002714278},
  keywords = {Justice, Institutional theory of desert, Rawls’ Priority Problem, Samuel Scheffler, Theory of Justice in Korea},
  abstract = {This article critically examines two questions from Dokyun Kim’s, Theory of Justice in Korea (hereinafter, ‘TJK’). First, it raises a question about the attempt to find the justice of Korean society in the constitution. Such an attempt seems to conflict with the role of the theory of justice in evaluating a social system. Second, the relationship between the principles of justice revealed in the discussion of TJK is obscure and is insufficient to solve “the priority problem”, which is the core task of the social justice theory raised by Rawls. For this, this paper explains the debate over the institutional view of desert and the priority problem of Rawls. Furthermore, the author’s position on the relationship between plural principles of justice, which is clearly revealed in Chapter 2 of TJK, should be reconstructed. This paper argues that Kim’s view stems from a series of misunderstandings about Rawls’ priority problem and the debates on Rawls’ institutional theory of desert, and that the attempt to raise the position of desert principle to a prima facie principle of pluralism has failed.},
  language = {en},
  title_native = {『한국 사회에서 정의란 무엇인가』에 대한 비판적 검토 ― 정의의 원천으로서의 헌법, 그리고 제도선행적 응분원칙의 이해에 대한 의문을 중심으로―},
  journal_native = {법철학연구},
  source_work_id = {ART002714278}
}

@article{ART002584158,
  author = {Son, Jeyoun},
  title = {Justification of a Moral Claim to Respect Human Dignity},
  journal = {Korean Journal of Legal Philosophy},
  year = {2020},
  volume = {23},
  number = {1},
  pages = {37-76},
  month = {Apr. 30.},
  doi = {10.22286/kjlp.2020.23.1.002},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART002584158},
  keywords = {Human Dignity, Strong Version of Dignitarianism, Justification, Legal Dignitarianism},
  abstract = {This paper examines the detailed theses to be argued in order to justify a moral claim to respect human dignity. In this context, human dignitarianism which conveys only trivial implications for practical discussion would be excluded. First of all, unlike the weak version of human dignitarianism, the strong version of human dignitarianism does not claim that it bypasses the existing established theory of ethics, but denotes that their thesis is independent of the existing ethical theories and is more fundamental than them. In contrast, the weak version of human dignitarianism argues that the very basic thesis of established ethical theory is the one to specify the claim, that is, “human dignity should be respected.” However, when observing the issues where the request for respect for human dignity appears desperately, we can see that the human dignitarianism that the modern society aspires to should be placed in a strong version. This is because these issues are difficult to address by superficial application of the existing ethical theories. Therefore, it is a strong view of human dignitarianism that deserves serious consideration. However, in order to justify this strong view, the detailed theses implied by this view should be explained with consistency with existing established ethical theories or provide the best explanation to overcome the established theory.The theses that need to be argued can be divided into two types in order to justify the strong version of human dignitarianism. One is about the thesis of what human dignity is, such as “human dignity is a value property of each human being.” The other is about the theses of the content, scope, and justification of the obligations brought about by the existence of human dignity, such as “the fact that someone holds this property places a certain obligation on all members of society for that holder.”, “The content of the obligation is to preserve, maintain, and develop the properties.”, and “This duty must be performed prior to any other duties.” Furthermore, there is the view that “the moral claim to respect human dignity necessarily implies the legal validity of specific norms with some content related to the guarantee of human dignity”, that is, legal human dignitarianism. In this regard, the thesis of legal human dignitarianism will be reviewed, and then the justifications for legal norms that are generally claimed to be inevitably derived from legal human dignitarianism will also be discussed.},
  language = {en},
  title_native = {인간존엄 존중 규범의 정당화},
  journal_native = {법철학연구},
  source_work_id = {ART002584158}
}

@article{ART002495391,
  author = {Son, Jeyoun},
  title = {Legal expressivism and the nature of expressive harm},
  journal = {Korean Journal of Legal Philosophy},
  year = {2019},
  volume = {22},
  number = {2},
  pages = {79-124},
  month = {Aug. 30.},
  doi = {10.22286/kjlp.2019.22.2.003},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART002495391},
  keywords = {Legal Expressivism, legal statements and their meanings, expressive harm, legitimacy},
  abstract = {Various claims have been attempted under the name of legal expressivism.This article categorizes legal expressivism into two broad categories: (1) a series of trends in which law seeks to extend the causal impact on society and its members’ behavioral changes, and (2) a view that notes the nature of the law as a semantically integrated system and argues that this nature provides a normative basis for legitimate law. Of these two, the argument that I want to pay attention to in this paper is the second view, which argues that legal expressivism further expands our understanding of the nature of law as a norm, thereby fundamentally changing our traditional view of recognizing the specific content of law.The expressive view becomes more apparent in the process of identifying the specific meaning of legal statements. The meaning of a legal statement must be grasped by observing internal acceptance of members of the society who incorporate the statement into their own legal system.Observing this behavior shows that social members associate legal statements with their value systems that are critically related to their humane lives, and accept the legal system as an integrated semantic system rather than as fragmented statements.Whereas existing non-expressive perspectives are concerned with the resulting benefits of applying the law to cases, the attention given to by legal expressivism lies in the benefits gained by maintaining the integrity of the semantics of legal system, and the expressive harm caused by the infringement of this integrity.Maintaining integrity of legal statements is particularly important because it is closely related to the interest of the community to maintain and preserve the members’ acceptance of the legal system and thereby to make the legal system the law of the society.},
  language = {en},
  title_native = {법적 표현주의와 표현적 해악의 본성},
  journal_native = {법철학연구},
  source_work_id = {ART002495391}
}

@article{ART002428217,
  author = {Son, Jeyoun},
  title = {Kant’s Conception of ‘Recht’},
  journal = {Korean Journal of Legal Philosophy},
  year = {2018},
  volume = {21},
  number = {3},
  pages = {53-88},
  month = {Dec.},
  doi = {10.22286/kjlp.2018.21.3.003},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART002428217},
  keywords = {Kant, The Metaphysics of Morals, the Doctrine of Right, Rechtslehre, law-rights-correctness, ‘Recht’ & ‘recht’, translation},
  abstract = {It is very encouraging that Korean translations of Kant’s Metaphysische Anfangsgründe der Rechtslehre (hereinafter Rechtslehre) is being offered in various versions by representative scholars. This article intends to be a guide for the beginners who want to study Kant’s legal theory. For this purpose, this article first examines the basic concepts of Kant’s Rechtslehre, such as juridical law-giving and the legality of acts.Secondly, This paper explains the repeated and serious misunder- standings surrounding the concept of ‘external freedom’. In Kant’s Rechtslehre, the concept of externality is used in duality and it must be clearly distinguished.Thirdly, on the basis of this understanding of the concept of external freedom, this paper explains the principle of coexistence of everyone’s freedom, which is the universal principle of the right, as an idea of ​​providing circumstances of morality. The concept of Recht should be understood as a concept that is based on morality, not a concept that is separate from morality.In addition, this paper deals with the difficulties in translation of core terms, such as ‘Recht’ and ‘recht’. Recht is mainly translated as ‘law(法)’. I would like to consider how to understand the term ‘Recht’ in Kant’s Rechtslehre, while looking at the alternative translations ‘correctness’ and ‘rights’.},
  language = {en},
  title_native = {칸트의 법(Recht) 관념―『법이론』에 등장하는 ‘외적 자유’ 개념을 중심으로―},
  journal_native = {법철학연구},
  source_work_id = {ART002428217}
}

@article{ART002344173,
  author = {Son, Jeyoun},
  title = {Understanding human dignity as a topological concept},
  journal = {Korean Journal of Legal Philosophy},
  year = {2018},
  volume = {21},
  number = {1},
  pages = {295-338},
  month = {Apr.},
  doi = {10.22286/kjlp.2018.21.1.008},
  url = {https://www.kci.go.kr/kciportal/ci/sereArticleSearch/ciSereArtiView.kci?sereArticleSearchBean.artiId=ART002344173},
  keywords = {human dignity, dignitas, high status, elevation of morality, topological concept, Kant, Jeremy Waldron, Oliver Sensen},
  abstract = {The concept of dignity can be found in Latin dignitas which means high rank of king or nobility. In this paper, I first classify the way of understanding the concept of dignity from dignitas as an elevated position to the human dignity that means an equal respect for all in contemporary human rights thought. The contemporary paradigm of human dignity, which is understood as a value property that grounds respect for others, causes various problems. In response to this, I would like to show that the concept of human dignity in contemporary thought also expresses the elevation of humanity or morality, and it inherits dignitas as a topological concept of classical high status in a manner.},
  language = {en},
  title_native = {위상적 개념으로서의 인간존엄},
  journal_native = {법철학연구},
  source_work_id = {ART002344173}
}
